---
// src/pages/admin/index.astro
---

<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>博客后台管理</title>
</head>
<body>
  <!-- Decap CMS 默认挂载到 id="nc-root"，但我们也显式指定 -->
  <div id="nc-root"></div>

  <script type="module">
    // ============================================================
    // 1. ★★★ 关键：在导入 CMS 之前设置手动初始化标志 ★★★
    // ============================================================
    window.CMS_MANUAL_INIT = true;

    // ============================================================
    // 2. 导入 Decap CMS
    // ============================================================
    import CMS, { init } from 'decap-cms-app';

    // ============================================================
    // 3. 处理 URL 中的 token（从 OAuth 回调带来）
    // ============================================================
    (function() {
      const urlParams = new URLSearchParams(window.location.search);
      const tokenFromUrl = urlParams.get('token');
      if (tokenFromUrl) {
        localStorage.setItem('github_token', tokenFromUrl);
        const cleanUrl = window.location.origin + window.location.pathname;
        window.history.replaceState({}, document.title, cleanUrl);
        console.log('✅ Token saved to localStorage');
      }
    })();

    // ============================================================
    // 4. 定义完整配置
    // ============================================================
    const CONFIG = {
      backend: {
        name: "github",
        repo: "fengliteam/schale",
        branch: "main",
        base_url: "https://www.xingying.us.kg",
        auth_endpoint: "/api/auth",
        auth: function() {
          const token = localStorage.getItem('github_token');
          if (token) {
            console.log('🔑 Using token from localStorage');
            return Promise.resolve({ token: token });
          }
          return Promise.resolve(null);
        }
      },
      media_folder: "public/img/uploads",
      public_folder: "/img/uploads",
      collections: [
        {
          name: "blog",
          label: "📄 博客文章",
          label_singular: "文章",
          folder: "src/content/blog",
          create: true,
          slug: "{{slug}}",
          path: "{{slug}}/index",
          preview_path: "article/{{slug}}",
          fields: [
            { name: "title", label: "文章标题", widget: "string" },
            { name: "date", label: "发布日期", widget: "datetime", date_format: "YYYY-MM-DD", time_format: false },
            { name: "updated", label: "更新日期", widget: "datetime", required: false, date_format: "YYYY-MM-DD", time_format: false },
            { name: "categories", label: "分类", widget: "string", required: false },
            { name: "tags", label: "标签", widget: "list", required: false },
            { name: "cover", label: "封面图", widget: "image", required: false },
            { name: "recommend", label: "⭐ 推荐文章", widget: "boolean", default: false },
            { name: "top", label: "📌 置顶文章", widget: "boolean", default: false },
            { name: "hide", label: "🙈 隐藏文章", widget: "boolean", default: false },
            { name: "type", label: "页面类型", widget: "select", options: [{ label: "普通文章", value: "" }, { label: "友链页", value: "links" }], default: "" },
            { name: "comment", label: "开启评论", widget: "boolean", default: true },
            { name: "body", label: "正文内容", widget: "markdown" }
          ],
          sortable_fields: ["date", "title"],
          default_sort: ["date", "desc"],
          view_filters: [
            { label: "全部文章", field: "hide", pattern: false },
            { label: "已隐藏", field: "hide", pattern: true },
            { label: "置顶文章", field: "top", pattern: true },
            { label: "推荐文章", field: "recommend", pattern: true }
          ]
        }
      ]
    };

    // ============================================================
    // 5. ★★★ 等待 DOM 就绪后初始化 ★★★
    // ============================================================
    function initializeCMS() {
      try {
        console.log('🚀 Initializing Decap CMS...');
        // ★★★ 关键：显式指定 root 挂载点 ★★★
        init({
          config: CONFIG,
          load_config_file: false,
          root: '#nc-root'   // 显式指定容器 ID
        });
        console.log('✅ Decap CMS initialized');
      } catch (error) {
        console.error('❌ Failed to initialize CMS:', error);
        // 在页面上显示错误信息，方便调试
        const root = document.getElementById('nc-root');
        if (root) {
          root.innerHTML = `<div style="color: red; padding: 20px;">
            <h3>CMS 初始化失败</h3>
            <pre>${error.message}</pre>
          </div>`;
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeCMS);
    } else {
      // DOM 已就绪，直接初始化
      initializeCMS();
    }
  </script>
</body>
</html>